# ============================================================
# RealSyncDynamics Agent-OS — Environment Variables
# Kopiere zu .env und fülle alle Werte aus.
# NIEMALS .env in Git committen — steht in .gitignore.
# Produktion: alle Werte über GCP Secret Manager (siehe docs/DEPLOY_GUIDE.md)
# ============================================================

# ── Datenbank ────────────────────────────────────────────────
# PostgreSQL 16 — lokal oder Cloud SQL
DATABASE_URL=postgresql://realsync:password@localhost:5432/realsync_agentdb
# Cloud SQL (via Cloud Run Secret): postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Redis (BullMQ) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Upstash (TLS): rediss://default:TOKEN@HOST:6380
# GCP Memorystore: redis://10.x.x.x:6379 (VPC Connector nötig)

# ── Auth (JWT) ───────────────────────────────────────────────
# Mindestens 64 Zeichen zufällig: openssl rand -hex 64
JWT_SECRET=REPLACE_ME_min64chars
JWT_REFRESH_SECRET=REPLACE_ME_min64chars_different
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── AI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
# Optional Serper (für research-agent web_search Fallback)
# SERPER_API_KEY=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Test: sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── OpenClaw Gateway ─────────────────────────────────────────
OPENCLAW_API_KEY=ocl_...
# Master-Key für Gateway-Registrierung
# OPENCLAW_MASTER_KEY=

# ── Interne Agent-Kommunikation ──────────────────────────────
# X-Agent-Key Header für /agent/* Routen
# openssl rand -hex 32
AGENT_INTERNAL_KEY=REPLACE_ME_32bytes_hex

# ── Gateway ──────────────────────────────────────────────────
GATEWAY_SECRET=REPLACE_ME_32bytes_hex

# ── Health Deep Endpoint ─────────────────────────────────────
# X-Internal-Key für /health/deep — nicht über LB exponieren
INTERNAL_HEALTH_KEY=REPLACE_ME_32bytes_hex

# ── E-Mail (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@realsync.io
SMTP_PASS=your-app-password
SMTP_FROM="RealSync Agent-OS <noreply@realsync.io>"

# ── Slack ────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Google Drive (invoice_to_archive Playbook) ───────────────
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_DRIVE_FOLDER_ID=1aBcDe...

# ── S3 / Cloud Storage ───────────────────────────────────────
# AWS oder GCS kompatibel
# S3_BUCKET=realsync-invoice-archive
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── BullMQ Workers ───────────────────────────────────────────
# true = Workers im selben Prozess starten (Cloud Run)
# false = Workers deaktiviert (z.B. in Tests oder separatem Job)
ENABLE_WORKERS=false
# Für Produktion auf true setzen sobald Redis konfiguriert:
# ENABLE_WORKERS=true

# ── App ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
# CORS: Flutter Web App URL oder * für alle
FRONTEND_URL=http://localhost:3000

# ── GCP (für lokales Deployment-Testing) ─────────────────────
GCP_PROJECT_ID=realsync-prod-001
GCP_REGION=europe-west1

# ── Tenant Defaults ──────────────────────────────────────────
# Standard-Schwellenwert für Human Approval in invoice_to_archive
DEFAULT_APPROVAL_THRESHOLD_EUR=1000
# Backup-Bucket für backup_verify Playbook
BACKUP_BUCKET=realsync-backups
