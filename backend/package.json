{
  "name": "realsync-agent-os-backend",
  "version": "1.3.0",
  "description": "RealSyncDynamics Agent-OS — Backend API Service",
  "main": "src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "lint": "eslint src/ --ext .js --max-warnings 0",
    "test": "jest --forceExit --detectOpenHandles --passWithNoTests",
    "test:ci": "jest --forceExit --detectOpenHandles --ci --coverage --passWithNoTests"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "bullmq": "^5.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.68.0",
    "pg": "^8.13.0",
    "stripe": "^17.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "nodemailer": "^6.9.15"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "statements": 40,
        "branches":   35,
        "functions":  40,
        "lines":      40
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/db/migrate.js",
      "!src/templates/**"
    ]
  }
}
