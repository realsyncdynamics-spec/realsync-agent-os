      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ],
      "queryParams": [],
      "bodyFields": [
        { "key": "email", "value": "[email]", "required": true },
        { "key": "password", "value": "[password]", "required": true }
      ],
      "responseFields": ["access_token", "refresh_token", "expires_in", "user"],
      "description": "Authentifiziert einen Nutzer und gibt JWT Access + Refresh Token zurück"
    },
    {
      "name": "AuthRegister",
      "method": "POST",
      "path": "/api/auth/register",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ],
      "queryParams": [],
      "bodyFields": [
        { "key": "email", "value": "[email]", "required": true },
        { "key": "password", "value": "[password]", "required": true },
        { "key": "display_name", "value": "[display_name]", "required": true },
        { "key": "tenant_name", "value": "[tenant_name]", "required": false }
      ],
      "responseFields": ["access_token", "refresh_token", "expires_in", "user", "tenant"],
