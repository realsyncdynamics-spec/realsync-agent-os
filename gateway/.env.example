# ============================================================
# OpenClaw Gateway Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# Required: API key used to authenticate requests from the backend.
# Minimum 32 characters. Generate with: openssl rand -hex 32
GATEWAY_API_KEY=your-secret-api-key-min-32-chars

# Unique identifier for this gateway instance.
# Shown in /health responses and backend dashboards.
GATEWAY_ID=gateway-prod-01

# Port the HTTP + WebSocket server listens on.
PORT=8443

# Directory where executable scripts are stored.
# Use an absolute path in production.
SCRIPTS_DIR=./scripts

# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Path to the rolling log file.
LOG_FILE=./logs/gateway.log

# Maximum job execution time in milliseconds (default: 5 minutes).
MAX_JOB_TIMEOUT_MS=300000

# Comma-separated list of allowed script file extensions.
ALLOWED_SCRIPT_EXTENSIONS=.sh,.ps1,.py

# Node.js environment. Set to "production" in deployed environments.
NODE_ENV=production
